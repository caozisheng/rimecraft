{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "RimeCraft",
	"version": "0.1.8",
	"identifier": "com.rimecraft.desktop",
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://127.0.0.1:1420",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "RimeCraft",
				"width": 1280,
				"height": 720,
				"minWidth": 960,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"linux": {
			"deb": {
				"depends": [
					"libwebkit2gtk-4.1-0",
					"libayatana-appindicator3-1"
				]
			},
			"rpm": {
				"depends": [
					"webkit2gtk4.1",
					"libayatana-appindicator-gtk3"
				]
			}
		}
	}
}
