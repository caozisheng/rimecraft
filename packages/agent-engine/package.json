{
	"name": "@rime/agent-engine",
	"version": "0.2.2",
	"private": false,
	"description": "Host-agnostic LLM agent engine with tool registry, streaming, and expert role orchestration",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsc --project tsconfig.json",
